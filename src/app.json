{
  "expo": {
    "scheme": "tackle",
    "name": "tackle",
    "slug": "tackle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icons/ProfileIcon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Backgrounds/PaperTexture.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ferroklaser.tackle",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icons/ProfileIcon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0feef38e-068e-463a-959e-2c3c8261329a"
      }
    },
    "owner": "jaepple",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0feef38e-068e-463a-959e-2c3c8261329a"
    }
  }
}
